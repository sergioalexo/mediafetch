{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MediaFetch",
  "version": "0.1.2",
  "identifier": "com.mediafetch.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SERGIO ALEXO / MediaFetch",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620,
        "dragDropEnabled": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFMzE0MzYyNkEzRjNCMzkKUldRNU96OXFZa014dms5bWJvN1FJZGJvUkJMSDBTaTZUSGdkVkRlNkJ3SGNCa1RDdFVkVThhckYK",
      "endpoints": [
        "https://github.com/sergioalexo/mediafetch/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
